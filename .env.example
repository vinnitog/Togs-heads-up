# Endpoints opcionais. Sem valor, a fonte aparece como "Pendente" (configuravel)
# ou "Sem acesso" (exige credencial/parceria oficial) no painel de Integracoes.
# As fontes G1, Giro Marilia, GMC Online e INMET ja funcionam sem configuracao.

# Endpoint JSON proprio/proxy com alertas normalizados.
VITE_INCIDENTS_API_URL=

# Waze for Cities: feed privado por orgao. Exige convenio oficial.
VITE_WAZE_FEED_URL=

# ARTESP: sem API publica em tempo real. Requer acesso oficial ou proxy proprio.
VITE_ARTESP_API_URL=

# INFOSIGA DETRAN-SP: base historica publica (dataset). Aponte para um proxy JSON se houver.
VITE_INFOSIGA_API_URL=

# SINESP: dados agregados de acesso restrito.
VITE_SINESP_API_URL=
