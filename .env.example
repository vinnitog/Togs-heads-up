# Opcional, mas RECOMENDADO. Sem valor, o app usa a DEMO_KEY da NASA, limitada a
# ~30 req/hora por IP e compartilhada entre APOD, NeoWs e Mars Rover -> gera HTTP 429.
# Gere uma chave gratuita em https://api.nasa.gov (limite ~1000 req/hora).
VITE_NASA_API_KEY=

# Proxy de CORS para fontes que nao enviam Access-Control-Allow-Origin
# (CPTEC/INPE e JPL SSD). Use {url} como marcador do endpoint alvo.
# Vazio DESATIVA o proxy (CPTEC/JPL ficarao indisponiveis no navegador).
# Sem definir, usa o padrao: https://api.allorigins.win/raw?url={url}
VITE_CORS_PROXY=

# Mantidos para compatibilidade com integracoes antigas de incidentes, caso sejam reativadas.
VITE_INCIDENTS_API_URL=
VITE_INFOSIGA_API_URL=
